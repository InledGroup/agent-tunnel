{
  "name": "agent-tunnel",
  "version": "1.0.0",
  "description": "Dale a tus agentes acceso a dispositivos remotos",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "electron:dev": "concurrently \"cd frontend && npm run dev\" \"wait-on http://localhost:4321 && electron .\"",
    "build:frontend": "cd frontend && npm run build",
    "build:app": "npm run build:frontend && electron-builder",
    "postinstall": "cd frontend && npm install"
  },
  "keywords": [],
  "author": "Inled Group <hi@inled.es>",
  "license": "ISC",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/InledGroup/agent-tunnel.git"
  },
  "dependencies": {
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.agenttunnel.app",
    "productName": "Agent Tunnel",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "main.js",
      "server.js",
      "scripts/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "icon": "logo.png",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "icon": "logo.png"
    },
    "linux": {
      "icon": "logo.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
