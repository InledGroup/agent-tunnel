---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Agent Tunnel | Pro">
    <!-- Activation Modal -->
    <div id="activation-modal" class="modal-overlay" style="display:none;">
        <div class="modal-card fade-in">
            <div class="modal-header">
                <div class="modal-title"><i class="fas fa-terminal"></i> Terminal Hook Activation</div>
                <button class="ghost-btn" onclick="closeModal()"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <p>Tunnel established! To intercept commands in your local terminal, run this in your project folder:</p>
                <div class="copy-box">
                    <code id="activation-cmd">source activate.sh</code>
                    <button class="ghost-btn" onclick="copyToClipboard('source activate.sh')"><i class="far fa-copy"></i></button>
                </div>
                <p style="font-size:11px; color:var(--text-muted); margin-top:12px;">
                    <i class="fas fa-info-circle"></i> Once activated, commands like <code>ls</code>, <code>mkdir</code>, or <code>node</code> will run on the remote target automatically.
                </p>
            </div>
            <div class="modal-footer">
                <button class="primary-btn" onclick="closeModal()">GOT IT!</button>
            </div>
        </div>
    </div>

    <div id="loading-overlay">
        <div class="spinner"></div>
        <div id="loading-txt">CONNECTING...</div>
        <button id="hide-loading-btn" class="secondary-btn">Hide Overlay</button>
    </div>

    <!-- Toast Container -->
    <div id="toast-container"></div>

    <aside>
        <div class="logo">
            <img src="https://hosted.inled.es/agent-tunnel-churro.png" alt="Agent Tunnel Logo" width="32" height="32" />
            <span>AGENT TUNNEL</span>
        </div>

        <section class="sessions-section" style="flex: 1; display: flex; flex-direction: column; overflow: hidden;">
            <div class="section-label"><i class="fas fa-history"></i> Recent Sessions</div>
            <div id="session-list" class="session-list"></div>
            <button id="new-session-btn" class="secondary-btn animate-hover" style="width:100%; margin-top:16px;">
                <i class="fas fa-plus"></i> New Tunnel
            </button>
        </section>

        <section class="status-section" style="margin-top: 24px;">
            <div class="section-label"><i class="fas fa-broadcast-tower"></i> Tunnel Status</div>
            <div class="status-badge">
                <div id="status-dot" class="status-dot"></div>
                <span id="status-text">Offline</span>
            </div>

            <div id="sync-progress-box" class="sync-progress-container" style="display:none;">
                <div class="progress-label">
                    <span id="sync-status-msg">Syncing...</span>
                    <span id="sync-percent">0%</span>
                </div>
                <div class="progress-bg"><div id="sync-bar" class="progress-fill"></div></div>
                <div id="sync-details"></div>
            </div>
        </section>
    </aside>

    <main>
        <div class="grid-layout">
            <div class="left-column">
                <div class="card fade-in">
                    <div class="section-label"><i class="fas fa-network-wired"></i> Remote Target</div>
                    <div class="field"><label>Friendly Name</label><input id="session_name" placeholder="e.g. Router-Lab"></div>
                    <div class="field"><label>Remote Host (IP or Domain)</label>
                        <div class="input-group"><i class="fas fa-globe"></i><input id="host" class="input-with-icon auto-connect" placeholder="192.168.1.1"></div>
                    </div>
                    <div class="grid-sub3">
                        <div class="field"><label>Username</label>
                            <div class="input-group"><i class="fas fa-user"></i><input id="user" class="input-with-icon auto-connect" placeholder="root"></div>
                        </div>
                        <div class="field"><label>Auth Password</label>
                            <div class="input-group"><i class="fas fa-shield-alt"></i><input type="password" id="pass" class="input-with-icon auto-connect" placeholder="••••••••"></div>
                        </div>
                        <div class="field"><label>Port</label>
                            <div class="input-group"><i class="fas fa-plug"></i><input id="port" class="input-with-icon auto-connect" placeholder="22"></div>
                        </div>
                    </div>

                    <div class="field"><label>Excluded Commands (Local-only)</label>
                        <div class="input-group"><i class="fas fa-filter"></i><input id="excluded_commands" class="input-with-icon" placeholder="e.g. gemini, git status, docker"></div>
                        <small style="color: #888; margin-top: 4px; display: block;">Comma-separated list of commands to NOT intercept.</small>
                    </div>
                    <div class="field"><label>Exclusion Mode</label>
                        <select id="exclude_mode" style="width: 100%; padding: 8px; border-radius: 6px; background: #222; color: #eee; border: 1px solid #444; margin-bottom: 10px;">
                            <option value="prefix">Starts with (Prefix)</option>
                            <option value="exact">Exact command match</option>
                        </select>
                    </div>

                    <div class="setting-item-inline">
                        <div class="setting-info">
                            <i class="fas fa-sync-alt"></i>
                            <span>File System Sync (Mutagen)</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" id="toggle-mutagen" checked>
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="action-buttons-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 4px;">
                        <button id="btn-save" class="secondary-btn animate-hover">
                            <i class="fas fa-save"></i> Save Changes
                        </button>
                        <button id="btn-test" class="secondary-btn animate-hover">
                            <i class="fas fa-flask"></i> Verify SSH
                        </button>
                    </div>
                </div>

                <div class="card fade-in" style="margin-top: 24px;">
                    <div class="section-label"><i class="fas fa-sliders-h"></i> Global Settings</div>
                    <div class="settings-grid">
                        <div class="setting-item">
                            <span class="setting-name">Terminal Hook</span>
                            <label class="switch">
                                <input type="checkbox" id="toggle-intercept">
                                <span class="slider"></span>
                            </label>
                        </div>
                        <div class="field">
                            <label>Instruction Filename</label>
                            <input id="instruction_filename" placeholder="GEMINI.md" style="font-family:'JetBrains Mono';">
                        </div>
                    </div>
                </div>
            </div>

            <div class="right-column">
                <div class="card fade-in">
                    <div class="section-label"><i class="fas fa-map-marked-alt"></i> Sync Map</div>
                    <div class="field">
                        <label>Local Working Directory</label>
                        <div id="local-container" class="explorer-container">
                            <div class="explorer-header">
                                <span class="explorer-path" id="local-nav">...</span>
                                <div id="local-spinner" class="spinner small" style="display:none;"></div>
                                <button class="ghost-btn" data-target="local-container"><i class="fas fa-expand-alt"></i></button>
                            </div>
                            <div class="explorer-search"><input type="text" placeholder="Filter..." class="exp-filter" data-list="local-list"></div>
                            <div id="local-list" class="explorer-list"></div>
                        </div>
                        <div id="local-sel" class="selection-path">Not mapped</div>
                    </div>
                    <div class="field">
                        <label>Remote Base Directory</label>
                        <div id="remote-container" class="explorer-container">
                            <div class="explorer-header">
                                <span class="explorer-path" id="remote-nav">/</span>
                                <div id="remote-spinner" class="spinner small" style="display:none;"></div>
                                <button class="ghost-btn" data-target="remote-container"><i class="fas fa-expand-alt"></i></button>
                            </div>
                            <div class="explorer-search"><input type="text" placeholder="Filter..." class="exp-filter" data-list="remote-list"></div>
                            <div id="remote-list" class="explorer-list"></div>
                        </div>
                        <div id="remote-sel" class="selection-path">Not mapped</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="action-bar fade-in">
            <button id="btn-establish" class="primary-btn animate-hover"><i class="fas fa-link"></i> ESTABLISH TUNNEL</button>
            <button id="btn-stop" class="danger-btn animate-hover" disabled><i class="fas fa-stop-circle"></i> STOP</button>
        </div>

        <div class="terminal fade-in">
            <div class="term-header">
                <span class="section-label" style="margin:0; color:var(--text);"><i class="fas fa-stream"></i> Tunnel Traffic</span>
                <button id="clear-logs-btn" class="ghost-btn"><i class="fas fa-eraser"></i></button>
            </div>
            <div id="term-body" class="term-body"></div>
        </div>
    </main>

    <script>
        // API Base URL Detection: Direct connection to avoid proxy issues in dev mode
        const API_BASE = window.location.port === '4321' ? 'http://localhost:3456' : '';
        
        let sessions = {}, selLocal = '', selRemote = '', explorersData = { 'local-list': null, 'remote-list': null };
        let currentStatus = { active: false, name: '' };
        let autoConnectTimer = null;
        let selectedSessionName = '';

        async function init() {
            lucide.createIcons();
            await loadSettings();
            await loadConfigs();
            setupSSE();
            setInterval(checkStatus, 2500); 
            checkStatus();
            browseLocal('');
            setupEventListeners();

            // Restaurar última sesión guardada en el navegador
            const lastSession = localStorage.getItem('last_session');
            if (lastSession && sessions[lastSession]) {
                const sessionCards = document.querySelectorAll('.session-card');
                let targetCard = null;
                sessionCards.forEach(c => {
                    if (c.querySelector('.name').innerText === lastSession) targetCard = c;
                });
                loadSession(lastSession, targetCard);
            }
        }

        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            const icon = type === 'success' ? 'fa-check-circle' : (type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle');
            toast.innerHTML = `<i class="fas ${icon}"></i> <span>${message}</span>`;
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(-20px)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function setupEventListeners() {
            document.getElementById('new-session-btn').onclick = newSession;
            document.getElementById('btn-test').onclick = testSSH;
            document.getElementById('btn-save').onclick = saveConfig;
            document.getElementById('btn-establish').onclick = activateBridge;
            document.getElementById('btn-stop').onclick = stopBridge;
            document.getElementById('clear-logs-btn').onclick = () => document.getElementById('term-body').innerHTML = '';
            document.getElementById('hide-loading-btn').onclick = () => document.getElementById('loading-overlay').style.display = 'none';
            document.getElementById('toggle-intercept').onchange = updateSettings;
            document.getElementById('instruction_filename').onchange = updateSettings;

            document.getElementById('toggle-mutagen').onchange = (e) => {
                const remoteCont = document.getElementById('remote-container');
                const remoteSel = document.getElementById('remote-sel');
                if (!e.target.checked) {
                    remoteCont.classList.add('disabled-explorer');
                    remoteSel.style.opacity = '0.5';
                    selRemote = 'N/A (SSH-Only)';
                    remoteSel.innerText = selRemote;
                } else {
                    remoteCont.classList.remove('disabled-explorer');
                    remoteSel.style.opacity = '1';
                    selRemote = '';
                    remoteSel.innerText = 'Not mapped';
                    autoBrowseRemote();
                }
            };
            document.querySelectorAll('.auto-connect').forEach(input => {
                input.addEventListener('input', () => {
                    clearTimeout(autoConnectTimer);
                    autoConnectTimer = setTimeout(autoBrowseRemote, 1000);
                });
            });

            document.querySelectorAll('.ghost-btn[data-target]').forEach(btn => {
                btn.onclick = () => {
                    const target = document.getElementById(btn.dataset.target);
                    target.classList.toggle('expanded');
                };
            });

            document.querySelectorAll('.exp-filter').forEach(input => {
                input.addEventListener('input', (e) => filterExplorer(input.dataset.list, e.target.value));
            });
        }

        async function loadSettings() {
            const r = await fetch(`${API_BASE}/api/settings`);
            const settings = await r.json();
            document.getElementById('toggle-intercept').checked = settings.intercept_terminal;
            document.getElementById('instruction_filename').value = settings.instruction_filename || 'GEMINI.md';
        }

        async function updateSettings() {
            const intercept_terminal = document.getElementById('toggle-intercept').checked;
            const instruction_filename = document.getElementById('instruction_filename').value || 'GEMINI.md';
            await fetch(`${API_BASE}/api/settings`, { method: 'POST', body: JSON.stringify({ intercept_terminal, instruction_filename }) });
            showToast('Settings saved', 'info');
        }

        function setupSSE() {
            const ev = new EventSource(`${API_BASE}/api/log-stream`);
            ev.onmessage = (e) => {
                const data = JSON.parse(e.data);
                if (data.type === 'system' || data.type === 'error') {
                    const txt = document.getElementById('loading-txt');
                    if (txt) txt.innerText = (data.message || data.output || 'Connecting...').substring(0, 60);
                }
                const body = document.getElementById('term-body');
                const line = document.createElement('div');
                line.className = 'log-line';
                let typeClass = 'sys', typeLabel = 'TUNNEL', content = data.output || data.cmd || data.message || '';
                if(data.type === 'command') { typeClass = 'exec'; typeLabel = 'REMOTE'; }
                if(data.type === 'result') { typeClass = data.exit_code === 0 ? 'out' : 'err'; typeLabel = 'TRAFFIC'; }
                if(data.type === 'error') { typeClass = 'err'; typeLabel = 'ERROR'; }
                line.innerHTML = `<div class="log-type ${typeClass}">${typeLabel}</div><div class="log-content">${content.replace(/</g, '&lt;')}</div>`;
                body.appendChild(line);
                body.scrollTop = body.scrollHeight;
            };
        }

        async function loadConfigs() {
            const r = await fetch(`${API_BASE}/api/get-configs`);
            sessions = await r.json();
            renderSessionList();
        }

        function renderSessionList() {
            const list = document.getElementById('session-list');
            list.innerHTML = '';
            Object.keys(sessions).forEach(name => {
                const s = sessions[name];
                const isActive = currentStatus.name === name && currentStatus.active;
                const isSelected = selectedSessionName === name;
                
                const div = document.createElement('div');
                div.className = `session-card ${isActive ? 'active-session' : ''} ${isSelected ? 'active-ui' : ''}`;
                div.innerHTML = `
                    <div class="session-info">
                        ${isActive ? '<div class="active-dot"></div>' : '<div class="inactive-dot"></div>'}
                        <div class="session-text">
                            <span class="name">${name}</span>
                            <span class="host">${s.user}@${s.host}</span>
                        </div>
                    </div>
                    <button class="btn-del" data-name="${name}"><i class="fas fa-times"></i></button>
                `;
                div.onclick = (e) => {
                    if (e.target.closest('.btn-del')) return;
                    loadSession(name, div);
                };
                div.querySelector('.btn-del').onclick = (e) => {
                    e.stopPropagation();
                    deleteSession(name);
                };
                list.appendChild(div);
            });
        }

        function loadSession(name, element) {
            selectedSessionName = name;
            localStorage.setItem('last_session', name); // Guardar para persistencia
            const s = sessions[name];
            document.getElementById('session_name').value = name;
            document.getElementById('host').value = s.host;
            document.getElementById('user').value = s.user;
            document.getElementById('port').value = s.port || '22';
            document.getElementById('pass').value = s.password || '';
            document.getElementById('toggle-mutagen').checked = s.use_mutagen !== false;
            document.getElementById('excluded_commands').value = s.excluded_commands || '';
            document.getElementById('exclude_mode').value = s.exclude_mode || 'prefix';
            
            // Handle visual state of remote explorer based on mutagen toggle
            const remoteCont = document.getElementById('remote-container');
            const remoteSelEl = document.getElementById('remote-sel');
            if (s.use_mutagen === false) {
                remoteCont.classList.add('disabled-explorer');
                remoteSelEl.style.opacity = '0.5';
                selRemote = 'N/A (SSH-Only)';
            } else {
                remoteCont.classList.remove('disabled-explorer');
                remoteSelEl.style.opacity = '1';
                selRemote = s.remote_path;
            }
            
            selLocal = s.local_path;
            document.getElementById('local-sel').innerText = selLocal;
            document.getElementById('remote-sel').innerText = selRemote;
            
            browseLocal(selLocal); 
            if (s.use_mutagen !== false) browseRemote(selRemote);
            
            document.querySelectorAll('.session-card').forEach(c => c.classList.remove('active-ui'));
            if (element) element.classList.add('active-ui');
            
            updateStopButton();
            showToast(`Loaded session: ${name}`, 'info');
        }

        async function browseLocal(path) {
            document.getElementById('local-spinner').style.display = 'block';
            try {
                const r = await fetch(`${API_BASE}/api/ls-local`, { method: 'POST', body: JSON.stringify({ path }) });
                const data = await r.json();
                explorersData['local-list'] = data;
                document.getElementById('local-nav').innerText = data.current;
                selLocal = data.current;
                document.getElementById('local-sel').innerText = selLocal;
                renderExp('local-list', data, browseLocal, (p) => { 
                    selLocal = p; 
                    document.getElementById('local-sel').innerText = p;
                    showToast(`Selected local folder: ${p.split('/').pop() || '/'}`, 'success');
                });
            } finally {
                document.getElementById('local-spinner').style.display = 'none';
            }
        }

        async function autoBrowseRemote() {
            const host = document.getElementById('host').value, user = document.getElementById('user').value;
            if (host && user && document.getElementById('toggle-mutagen').checked) browseRemote('/');
        }

        async function browseRemote(path = '/') {
            const host = document.getElementById('host').value, 
                  user = document.getElementById('user').value, 
                  port = document.getElementById('port').value || '22',
                  pass = document.getElementById('pass').value;
            if (!host || !user || !document.getElementById('toggle-mutagen').checked) return;
            document.getElementById('remote-spinner').style.display = 'block';
            try {
                const r = await fetch(`${API_BASE}/api/ls-remote`, { method: 'POST', body: JSON.stringify({ host, user, port, password: pass, remote_path: path }) });
                const data = await r.json();
                if (data.error) {
                    showToast(`Remote Error: ${data.error}`, 'error');
                    return;
                }
                explorersData['remote-list'] = data;
                document.getElementById('remote-nav').innerText = data.current;
                selRemote = data.current;
                document.getElementById('remote-sel').innerText = selRemote;
                renderExp('remote-list', data, browseRemote, (p) => { 
                    selRemote = p; 
                    document.getElementById('remote-sel').innerText = p;
                    showToast(`Selected remote folder: ${p.split('/').pop() || '/'}`, 'success');
                });
            } finally {
                document.getElementById('remote-spinner').style.display = 'none';
            }
        }

        function filterExplorer(id, query) {
            const list = explorersData[id];
            if (!list || !list.dirs) return;
            const filteredDirs = list.dirs.filter(d => d.toLowerCase().includes(query.toLowerCase()));
            renderExp(id, { ...list, dirs: filteredDirs }, id === 'local-list' ? browseLocal : browseRemote, (p) => {
                if (id === 'local-list') { selLocal = p; document.getElementById('local-sel').innerText = p; }
                else { selRemote = p; document.getElementById('remote-sel').innerText = p; }
            });
        }

        function renderExp(id, data, onNav, onSel) {
            const el = document.getElementById(id); el.innerHTML = '';
            if (!data || !data.current) return;

            const up = document.createElement('div'); up.className = 'explorer-item'; 
            up.innerHTML = '<i class="fas fa-chevron-up"></i> .. [Go Up]';
            up.onclick = () => { 
                let pathStr = data.current;
                // Eliminar barra final si existe
                if (pathStr.endsWith('/') && pathStr.length > 1) pathStr = pathStr.slice(0, -1);
                const parts = pathStr.split('/').filter(x => x);
                parts.pop();
                const parentPath = '/' + parts.join('/');
                onNav(parentPath); 
            };
            el.appendChild(up);
            
            const selCurrent = document.createElement('div'); selCurrent.className = 'explorer-item selected';
            selCurrent.innerHTML = '<i class="fas fa-crosshairs"></i> [Select Folder]';
            selCurrent.onclick = () => { onSel(data.current); };
            el.appendChild(selCurrent);
            
            if (data.dirs) {
                data.dirs.forEach(d => {
                    const item = document.createElement('div'); item.className = 'explorer-item folder'; 
                    item.innerHTML = '<i class="fas fa-folder"></i> ' + d;
                    const nextPath = data.current + (data.current.endsWith('/') ? '' : '/') + d;
                    item.onclick = () => onNav(nextPath);
                    el.appendChild(item);
                });
            }
        }

        async function checkStatus() {
            try {
                const r = await fetch(`${API_BASE}/api/sessions`);
                const data = await r.json();
                const out = data.output || '';
                const activeSsh = data.activeSsh || {};
                const dot = document.getElementById('status-dot');
                const txt = document.getElementById('status-text');
                const progBox = document.getElementById('sync-progress-box');
                
                const isWatching = out.includes("Status: Watching for changes");
                const isStaging = out.includes("Status: Staging") || out.includes("Status: Synchronizing") || out.includes("Status: Reconciling");
                const isActiveMutagen = out.includes("Name:");
                
                // Comprobar si hay alguna sesión SSH activa manual (sin mutagen)
                const currentSessionName = document.getElementById('session_name').value;
                const validCurrentName = currentSessionName.replace(/\s+/g, '-').replace(/[^a-zA-Z0-9-_]/g, '');
                const isSshActive = activeSsh[validCurrentName] !== undefined;

                const nameMatch = out.match(/Name: "([^"]+)"/);
                const prevActive = currentStatus.active;
                currentStatus.active = isActiveMutagen || isWatching || isStaging || isSshActive;
                currentStatus.name = nameMatch ? nameMatch[1] : (isSshActive ? currentSessionName : '');

                if (currentStatus.active && !prevActive) {
                    showToast(`Tunnel "${currentStatus.name}" is now online`, 'success');
                }

                if (isWatching || (isSshActive && !isStaging)) {
                    dot.className = 'status-dot active'; 
                    txt.innerText = isSshActive && !isActiveMutagen ? 'Stable Connection (SSH-Only)' : 'Stable Connection'; 
                    progBox.style.display = 'none';
                } else if (isStaging) {
                    dot.className = 'status-dot syncing'; txt.innerText = 'Synchronizing...'; progBox.style.display = 'block';
                    const matchPercent = out.match(/(\d+)%/), matchEntries = out.match(/(\d+\/\d+ entries)/) || out.match(/(\d+ entries)/), statusMsg = out.match(/Status: ([^\n\(]+)/);
                    if (matchPercent) { document.getElementById('sync-percent').innerText = matchPercent[0]; document.getElementById('sync-bar').style.width = matchPercent[0]; }
                    else { document.getElementById('sync-percent').innerText = '...'; document.getElementById('sync-bar').style.width = '100%'; }
                    if (statusMsg) document.getElementById('sync-status-msg').innerText = statusMsg[1].trim();
                    if (matchEntries) document.getElementById('sync-details').innerText = matchEntries[0];
                } else if (isActive) {
                    dot.className = 'status-dot syncing'; txt.innerText = 'Establishing...'; progBox.style.display = 'block';
                } else {
                    dot.className = 'status-dot'; txt.innerText = 'Offline'; progBox.style.display = 'none';
                }

                updateStopButton();
                renderSessionList();
            } catch(e) {}
        }

        function updateStopButton() {
            const btnStop = document.getElementById('btn-stop');
            const currentInputName = document.getElementById('session_name').value;
            if (currentStatus.active && currentStatus.name === currentInputName) {
                btnStop.disabled = false;
                btnStop.classList.add('active-danger');
            } else {
                btnStop.disabled = true;
                btnStop.classList.remove('active-danger');
            }
        }

        window.closeModal = () => document.getElementById('activation-modal').style.display = 'none';
        window.openModal = () => document.getElementById('activation-modal').style.display = 'flex';
        window.copyToClipboard = (text) => {
            navigator.clipboard.writeText(text);
            showToast('Copied to clipboard!', 'info');
        };

        async function saveConfig() {
            const name = document.getElementById('session_name').value, 
                  host = document.getElementById('host').value, 
                  user = document.getElementById('user').value, 
                  port = document.getElementById('port').value || '22',
                  pass = document.getElementById('pass').value, 
                  useMutagen = document.getElementById('toggle-mutagen').checked,
                  excludedCommands = document.getElementById('excluded_commands').value,
                  excludeMode = document.getElementById('exclude_mode').value;

            if (!name) {
                showToast('Please enter a session name', 'error');
                return;
            }

            try {
                const r = await fetch(`${API_BASE}/api/config`, { 
                    method: 'POST', 
                    body: JSON.stringify({ 
                        session_name: name, 
                        host, 
                        user, 
                        port,
                        password: pass, 
                        local_path: selLocal, 
                        remote_path: useMutagen ? selRemote : '/tmp/ssh-only', 
                        use_mutagen: useMutagen,
                        excluded_commands: excludedCommands,
                        exclude_mode: excludeMode,
                        only_save: true
                    }) 
                });

                const data = await r.json();
                if (r.ok) { 
                    showToast('Configuration saved!', 'success'); 
                    loadConfigs();
                } else { 
                    showToast('Save Error: ' + data.message, 'error'); 
                }
            } catch(e) { 
                showToast('Error: ' + e.message, 'error'); 
            }
        }

        async function activateBridge() {
            const name = document.getElementById('session_name').value, 
                  host = document.getElementById('host').value, 
                  user = document.getElementById('user').value, 
                  port = document.getElementById('port').value || '22',
                  pass = document.getElementById('pass').value, 
                  useMutagen = document.getElementById('toggle-mutagen').checked,
                  excludedCommands = document.getElementById('excluded_commands').value,
                  excludeMode = document.getElementById('exclude_mode').value;

            if (!name || !host || !user || !selLocal || (useMutagen && !selRemote)) {
                showToast('Please fill all fields and select paths', 'error');
                return;
            }
            const configRemotePath = useMutagen ? selRemote : '/tmp/ssh-only';

            document.getElementById('loading-overlay').style.display = 'flex';
            try {
                const r = await fetch(`${API_BASE}/api/config`, { 
                    method: 'POST', 
                    body: JSON.stringify({ 
                        session_name: name, 
                        host, 
                        user, 
                        port,
                        password: pass, 
                        local_path: selLocal, 
                        remote_path: configRemotePath, 
                        use_mutagen: useMutagen,
                        excluded_commands: excludedCommands,
                        exclude_mode: excludeMode
                    }) 
                });

                document.getElementById('loading-overlay').style.display = 'none';
                const data = await r.json();
                if (data.status === 'warning') { 
                    showToast(data.message, 'info'); 
                } else if (r.ok) { 
                    showToast('Establishing Tunnel...', 'success'); 
                    setTimeout(openModal, 1500); // Abrir modal de instrucciones
                } else { 
                    showToast('Tunnel Failure: ' + data.message, 'error'); 
                }
                loadConfigs();
            } catch(e) { 
                document.getElementById('loading-overlay').style.display = 'none'; 
                showToast('Error: ' + e.message, 'error'); 
            }
        }

        async function stopBridge() {
            const name = document.getElementById('session_name').value;
            if (!name) return;
            if (!confirm(`Stop tunnel and deactivate bridge for "${name}"?`)) return;
            
            try {
                // 1. Detener en el servidor (Mutagen + SSH record)
                const r = await fetch(`${API_BASE}/api/stop-session`, { method: 'POST', body: JSON.stringify({ name }) });
                
                // 2. Limpiar archivos locales (Desactivar bridge)
                await fetch(`${API_BASE}/api/cleanup-local`, { method: 'POST', body: JSON.stringify({ local_path: selLocal }) });

                if (r.ok) {
                    showToast('Tunnel & Bridge Stopped', 'success');
                    currentStatus.active = false;
                    currentStatus.name = '';
                    updateStopButton();
                    renderSessionList();
                } else showToast('Error: ' + (await r.json()).message, 'error');
                checkStatus();
            } catch(e) { showToast('Error: ' + e.message, 'error'); }
        }

        async function testSSH() {
            const host = document.getElementById('host').value, 
                  user = document.getElementById('user').value, 
                  port = document.getElementById('port').value || '22',
                  pass = document.getElementById('pass').value;
            if (!host || !user) {
                showToast('Enter host and user first', 'error');
                return;
            }
            const btn = document.getElementById('btn-test'); btn.disabled = true; btn.innerText = 'Checking...';
            try {
                const r = await fetch(`${API_BASE}/api/test-ssh`, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({host, user, port, password: pass}) });
                const data = await r.json();
                if (data.status === 'success') {
                    showToast('SSH Access Confirmed!', 'success');
                    if (document.getElementById('toggle-mutagen').checked) browseRemote('/');
                } else {
                    showToast('Access Denied: ' + data.message, 'error');
                }
            } catch(e) { showToast('Error: ' + e.message, 'error'); }
            btn.disabled = false; btn.innerText = 'Verify SSH Access';
        }

        async function deleteSession(name) { 
            if (!confirm(`Delete ${name}?`)) return; 
            await fetch(`${API_BASE}/api/delete-session`, { method: 'POST', body: JSON.stringify({ name }) }); 
            showToast(`Deleted ${name}`, 'info');
            loadConfigs(); 
        }

        function newSession() { 
            selectedSessionName = '';
            document.querySelectorAll('input:not([type=checkbox])').forEach(i => i.value=''); 
            document.getElementById('toggle-mutagen').checked = true;
            
            const remoteCont = document.getElementById('remote-container');
            const remoteSelEl = document.getElementById('remote-sel');
            remoteCont.classList.remove('disabled-explorer');
            remoteSelEl.style.opacity = '1';
            
            selLocal=''; selRemote=''; 
            document.getElementById('local-sel').innerText='Not mapped'; 
            document.getElementById('remote-sel').innerText='Not mapped'; 
            document.querySelectorAll('.session-card').forEach(c => c.classList.remove('active-ui'));
            updateStopButton();
            showToast('Ready for new tunnel', 'info');
        }

        init();
    </script>
</Layout>

